{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Note Aura",
  "version": "0.1.3",
  "identifier": "com.axel.noteaura",
  "build": {
    "beforeDevCommand": "npm run plugin:mvp:build && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run plugin:host:prepare && npm run plugin:bundle:prepare && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Note Aura",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/na-plugin-host"],
    "resources": {
      "resources/plugins/": "plugins/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
