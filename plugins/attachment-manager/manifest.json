{
  "schemaVersion": 1,
  "apiVersion": "1",
  "id": "dev.gittributary.attachment-manager",
  "name": "附件",
  "icon": "lucide:paperclip",
  "description": "浏览仓库附件、检查 Markdown 引用与孤立文件。",
  "version": "0.1.1",
  "publisher": "GitTributary",
  "engines": {
    "gittributary": ">=0.1.3"
  },
  "contributes": {
    "views": [
      {
        "id": "attachment-manager.main",
        "title": "附件",
        "description": "仓库附件与引用关系。",
        "location": "activitybar",
        "entry": "frontend/dist/index.html"
      }
    ]
  },
  "backend": {
    "runtime": "rust-cdylib",
    "entry": "backend/target/release",
    "library": "attachment_manager_plugin",
    "methods": {
      "attachments.scan": ["files:read"],
      "attachments.preview": ["files:read"]
    }
  },
  "activationEvents": [
    "onView:attachment-manager.main"
  ],
  "permissions": [
    "repository:read",
    "files:read",
    "store:read",
    "store:write",
    "shell:open"
  ]
}
