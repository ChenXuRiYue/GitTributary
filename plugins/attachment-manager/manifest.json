{
  "schemaVersion": 1,
  "apiVersion": "1",
  "id": "dev.noteaura.attachment-manager",
  "name": "附件",
  "icon": "lucide:paperclip",
  "description": "盘点仓库附件与远程链接，并将 Markdown 本地图片迁移到 GitHub 图床。",
  "version": "0.4.9",
  "publisher": "Note Aura",
  "engines": {
    "noteaura": ">=0.1.3"
  },
  "contributes": {
    "views": [
      {
        "id": "attachment-manager.main",
        "title": "附件",
        "description": "仓库附件与引用关系。",
        "location": "activitybar",
        "entry": "frontend/dist/index.html"
      }
    ]
  },
  "backend": {
    "runtime": "rust-cdylib",
    "entry": "backend/target/release",
    "library": "attachment_manager_plugin",
    "methods": {
      "attachments.scan": ["files:read"],
      "attachments.preview": ["files:read"],
      "attachments.previewChunk": ["files:read"],
      "attachments.checkGithubImageConfig": ["network:read", "git:credential"],
      "attachments.migrateGithubImages": ["files:read", "files:write", "network:write", "git:credential"]
    }
  },
  "activationEvents": [
    "onView:attachment-manager.main"
  ],
  "permissions": [
    "repository:read",
    "git:write",
    "git:credential",
    "files:read",
    "files:write",
    "store:read",
    "store:write",
    "shell:open",
    "network:read",
    "network:write"
  ]
}
