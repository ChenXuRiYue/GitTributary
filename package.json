{
  "name": "gittributary",
  "private": true,
  "version": "0.1.3",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "plugins/*/frontend"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ChenXuRiYue/GitTributary.git"
  },
  "homepage": "https://github.com/ChenXuRiYue/GitTributary#readme",
  "bugs": {
    "url": "https://github.com/ChenXuRiYue/GitTributary/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "plugin:host:build": "cargo build --manifest-path src-tauri/Cargo.toml -p gt-plugin-host",
    "plugin:host:prepare": "node scripts/prepare_plugin_host.mjs",
    "plugin:build": "node scripts/build_plugins.mjs",
    "plugin:bundle:prepare": "npm run plugin:build && node scripts/prepare_plugins.mjs",
    "plugin:mvp:build": "npm run plugin:host:prepare && npm run plugin:build"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
