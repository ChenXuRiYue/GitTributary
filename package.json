{
  "name": "gittributary",
  "private": true,
  "version": "0.1.3",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "plugins/*/frontend"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ChenXuRiYue/GitTributary.git"
  },
  "homepage": "https://github.com/ChenXuRiYue/GitTributary#readme",
  "bugs": {
    "url": "https://github.com/ChenXuRiYue/GitTributary/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:types": "tsc --project tsconfig.test.json && npm run typecheck --workspaces --if-present",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:report": "node scripts/test/run-report.mjs",
    "test:report:standard": "node scripts/test/run-report.mjs --profile standard",
    "test:report:full": "node scripts/test/run-report.mjs --profile full --coverage",
    "test:report:ci": "node scripts/test/run-report.mjs --profile ci --coverage --rust-runner nextest",
    "test:report:self": "node --test scripts/test/*.test.mjs",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --workspace --all-targets",
    "test:rust:nextest": "cargo nextest run --manifest-path src-tauri/Cargo.toml --workspace --all-targets",
    "bench:rust": "cargo bench --manifest-path src-tauri/Cargo.toml --bench core_operations",
    "test:plugins": "npm run test:report -- --only plugins",
    "test:fast": "npm run test:report",
    "test:all": "npm run test:report:full",
    "tauri": "tauri",
    "plugin:host:build": "cargo build --manifest-path src-tauri/Cargo.toml -p gt-plugin-host",
    "plugin:host:prepare": "node scripts/prepare_plugin_host.mjs",
    "plugin:boundary": "node scripts/check_plugin_core_boundary.mjs",
    "plugin:build": "npm run plugin:boundary && node scripts/build_plugins.mjs",
    "plugin:bundle:prepare": "npm run plugin:build && node scripts/prepare_plugins.mjs",
    "plugin:mvp:build": "npm run plugin:host:prepare && npm run plugin:build",
    "perf:contract": "node scripts/check_git_performance_contract.mjs",
    "perf:rust": "cargo test --manifest-path src-tauri/Cargo.toml -p gt-git --release --test performance_test -- --ignored --nocapture --test-threads=1",
    "perf:attachments": "cargo test --manifest-path plugins/attachment-manager/backend/Cargo.toml --release classifies_large_link_inventory_within_budget -- --ignored --nocapture --test-threads=1",
    "perf:ipc": "node scripts/perf/run-ipc.mjs --output performance/reports/latest/metrics.json",
    "perf:report": "node scripts/perf/render-report.mjs --input performance/reports/latest/metrics.json --model performance/model.json --output performance/reports/latest",
    "perf:check": "npm run perf:contract && npm run perf:rust && npm run perf:attachments",
    "perf:ci": "node scripts/perf/run-all.mjs"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.10",
    "fast-check": "^4.9.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
